# Example environment variables
# Copy this file to .env.local for local development

# PostgreSQL Database Configuration
# For local development: postgresql://postgres:password@localhost:5432/database_name
# For Vercel/Production (Neon): postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
